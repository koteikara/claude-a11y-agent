# Google service-account JSON key path. Do not commit the key itself.
GOOGLE_APPLICATION_CREDENTIALS=/secure/path/to/service-account.json

# Optional command defaults for local shells/CI wrappers.
A11Y_SHEET_ID=your-google-sheet-id
A11Y_SITE=saga-city

# Optional LLM settings used by a11y_testkit/llm.py / engine adapter.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
CLAUDE_MODEL=claude-sonnet-4-20250514
