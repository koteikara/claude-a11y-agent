# Local development configuration for the runner and web backend.
# Copy to .env only for local use. Do not put real secrets in this file.

# Google auth:
# - Cloud Run Service/Jobs: leave GOOGLE_APPLICATION_CREDENTIALS unset and use
#   the Cloud Run execution service account (ADC).
# - Local: run `gcloud auth application-default login` OR, only when unavoidable,
#   set GOOGLE_APPLICATION_CREDENTIALS to a local JSON key path outside this repo.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/outside/repo/service-account.json

# Google Sheets management ledger. The runner accepts --sheet explicitly; if
# omitted it falls back to A11Y_SHEET_ID, GOOGLE_SHEET_ID, then SHEET_ID.
A11Y_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_ID=your-google-sheet-id
SHEET_ID=your-google-sheet-id

# Optional command defaults for local shells/CI wrappers.
A11Y_SITE=saga-city
A11Y_LIMIT=10

# Optional LLM settings used by a11y_testkit/llm.py / engine adapter.
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-pro
CLAUDE_MODEL=claude-sonnet-4-20250514

# Secrets: keep real values in Secret Manager for Cloud Run, or in an untracked
# local .env file for development only.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Web admin local-only auth fallback. In production, protect Cloud Run with IAM
# and/or IAP; Basic auth may be added as a second layer via Secret Manager.
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me
PORT=8080
