# Local development configuration for the Web admin backend.
# Copy to web/.env or export these variables locally. Do not commit secrets.

# Google auth:
# - Cloud Run: leave GOOGLE_APPLICATION_CREDENTIALS unset and use the execution
#   service account via Application Default Credentials.
# - Local: use `gcloud auth application-default login` OR, only when unavoidable,
#   set a JSON key path outside the repository.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/outside/repo/service-account.json

# Required for the web backend.
GOOGLE_SHEET_ID=your-google-sheet-id
# SHEET_ID is accepted as a fallback for compatibility.
SHEET_ID=your-google-sheet-id

# The backend reads these folder IDs from the Config sheet, but keeping them
# documented here helps operators validate local/Cloud Run settings.
DRIVE_INPUT_FOLDER_ID=your-input-folder-id
DRIVE_OUTPUT_AI_FOLDER_ID=your-ai-folder-id
DRIVE_OUTPUT_GOLD_FOLDER_ID=your-gold-folder-id

# Recommended production posture: Cloud Run IAM / IAP + --no-allow-unauthenticated.
# Basic auth is a local/private fallback. Set both values or the UI/API returns 503.
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=change-me
PORT=8080

# Test-only; never set on Cloud Run.
AUTH_DISABLED_FOR_TESTS=false
